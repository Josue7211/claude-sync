#!/usr/bin/env bash
# claude-sync - Sync Claude Code configuration across machines
# https://github.com/aparcedodev/claude-sync

set -euo pipefail

VERSION="1.0.0"
CONFIG_DIR="${CLAUDE_SYNC_CONFIG_DIR:-$HOME/.config/claude-sync}"
CONFIG_FILE="$CONFIG_DIR/config.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────

log()   { echo -e "${GREEN}${BOLD}✓${NC} $*"; }
warn()  { echo -e "${YELLOW}${BOLD}!${NC} $*"; }
err()   { echo -e "${RED}${BOLD}✗${NC} $*" >&2; }
info()  { echo -e "${BLUE}${BOLD}→${NC} $*"; }
dim()   { echo -e "${DIM}$*${NC}"; }

die() { err "$@"; exit 1; }

need() {
    command -v "$1" &>/dev/null || die "Required: $1 (install it first)"
}

# ─────────────────────────────────────────────
# Config management
# ─────────────────────────────────────────────

config_exists() { [[ -f "$CONFIG_FILE" ]]; }

read_config() {
    python3 -c "
import json, sys
with open('$CONFIG_FILE') as f:
    c = json.load(f)
print(json.dumps(c))
" 2>/dev/null || echo "{}"
}

get_targets() {
    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    c = json.load(f)
for name, t in c.get('targets', {}).items():
    print(f\"{name}\t{t['host']}\t{t.get('user','')}\t{t.get('auth','key')}\")
" 2>/dev/null
}

get_target() {
    local name="$1"
    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    c = json.load(f)
t = c.get('targets', {}).get('$name')
if not t:
    exit(1)
print(json.dumps(t))
" 2>/dev/null
}

get_sync_items() {
    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    c = json.load(f)
items = c.get('sync', ['settings.json', 'rules', 'agents', 'skills', 'commands', 'hooks', '.mcp.json'])
for i in items:
    print(i)
" 2>/dev/null
}

get_path_mappings() {
    local target="$1"
    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    c = json.load(f)
t = c.get('targets', {}).get('$target', {})
mappings = t.get('pathMappings', {})
for src, dst in mappings.items():
    print(f'{src}\t{dst}')
" 2>/dev/null
}

# ─────────────────────────────────────────────
# SSH helpers
# ─────────────────────────────────────────────

target_ssh() {
    local target_json="$1"
    shift
    local host user auth pass port

    host=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t['host'])")
    user=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('user',''))")
    auth=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('auth','key'))")
    pass=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('password',''))")
    port=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('port', 22))")

    local ssh_target="${user:+$user@}$host"
    local ssh_opts="-o ConnectTimeout=10 -o StrictHostKeyChecking=no -p $port"

    if [[ "$auth" == "password" && -n "$pass" ]]; then
        need sshpass
        sshpass -p "$pass" ssh $ssh_opts "$ssh_target" "$@"
    else
        ssh $ssh_opts "$ssh_target" "$@"
    fi
}

target_rsync() {
    local target_json="$1"
    local src="$2"
    local dst="$3"

    local host user auth pass port

    host=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t['host'])")
    user=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('user',''))")
    auth=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('auth','key'))")
    pass=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('password',''))")
    port=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('port', 22))")

    local ssh_target="${user:+$user@}$host"
    local rsync_ssh="ssh -o StrictHostKeyChecking=no -p $port"

    if [[ "$auth" == "password" && -n "$pass" ]]; then
        need sshpass
        rsync_ssh="sshpass -p '$pass' ssh -o StrictHostKeyChecking=no -p $port"
    fi

    rsync -az --delete -e "$rsync_ssh" "$src" "$ssh_target:$dst"
}

target_scp() {
    local target_json="$1"
    local src="$2"
    local dst="$3"

    local host user auth pass port

    host=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t['host'])")
    user=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('user',''))")
    auth=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('auth','key'))")
    pass=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('password',''))")
    port=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('port', 22))")

    local ssh_target="${user:+$user@}$host"
    local scp_opts="-o StrictHostKeyChecking=no -P $port"

    if [[ "$auth" == "password" && -n "$pass" ]]; then
        need sshpass
        sshpass -p "$pass" scp $scp_opts "$src" "$ssh_target:$dst"
    else
        scp $scp_opts "$src" "$ssh_target:$dst"
    fi
}

# ─────────────────────────────────────────────
# Path fixing
# ─────────────────────────────────────────────

fix_paths_in_file() {
    local target_name="$1"
    local target_json="$2"
    local remote_file="$3"

    local mappings
    mappings=$(get_path_mappings "$target_name")

    if [[ -z "$mappings" ]]; then
        return 0
    fi

    # Build sed commands for all path mappings
    local sed_script=""
    while IFS=$'\t' read -r src dst; do
        # Escape slashes for sed
        local esc_src="${src//\//\\/}"
        local esc_dst="${dst//\//\\/}"
        sed_script="${sed_script}s/${esc_src}/${esc_dst}/g;"
    done <<< "$mappings"

    if [[ -n "$sed_script" ]]; then
        target_ssh "$target_json" "sed -i.bak '${sed_script}' '$remote_file' && rm -f '${remote_file}.bak'"
    fi
}

# ─────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────

cmd_init() {
    if config_exists; then
        warn "Config already exists at $CONFIG_FILE"
        read -rp "Overwrite? (y/N) " yn
        [[ "$yn" =~ ^[Yy]$ ]] || return 0
    fi

    mkdir -p "$CONFIG_DIR"

    local claude_dir="$HOME/.claude"
    local home_dir="$HOME"

    cat > "$CONFIG_FILE" << EOF
{
  "source": {
    "claudeDir": "$claude_dir",
    "mcpJson": "$home_dir/.mcp.json"
  },
  "sync": [
    "settings.json",
    "rules",
    "agents",
    "skills",
    "commands",
    "hooks",
    ".mcp.json"
  ],
  "targets": {}
}
EOF

    log "Config created at $CONFIG_FILE"
    echo ""
    info "Next: add a target machine with:"
    dim "  claude-sync add <name> --host <ip> --user <user> [--password <pass>] [--port 22]"
}

cmd_add() {
    config_exists || die "No config. Run: claude-sync init"

    local name="" host="" user="" password="" port="22" auth="key"
    local remote_home=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --host)     host="$2"; shift 2 ;;
            --user)     user="$2"; shift 2 ;;
            --password) password="$2"; auth="password"; shift 2 ;;
            --port)     port="$2"; shift 2 ;;
            --home)     remote_home="$2"; shift 2 ;;
            *)          [[ -z "$name" ]] && name="$1" || die "Unknown arg: $1"; shift ;;
        esac
    done

    [[ -n "$name" ]] || die "Usage: claude-sync add <name> --host <ip> --user <user>"
    [[ -n "$host" ]] || die "Missing --host"

    # Auto-detect remote home if not specified
    if [[ -z "$remote_home" ]]; then
        local target_json="{\"host\":\"$host\",\"user\":\"$user\",\"auth\":\"$auth\",\"password\":\"$password\",\"port\":$port}"
        info "Detecting remote home directory..."
        remote_home=$(target_ssh "$target_json" "echo \$HOME" 2>/dev/null) || die "Cannot connect to $host"
    fi

    local local_home="$HOME"

    # Build path mappings if homes differ
    local path_mappings="{}"
    if [[ "$local_home" != "$remote_home" ]]; then
        path_mappings="{\"$local_home/\": \"$remote_home/\"}"
        info "Path mapping: $local_home/ → $remote_home/"
    fi

    python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    c = json.load(f)

c.setdefault('targets', {})['$name'] = {
    'host': '$host',
    'user': '$user',
    'auth': '$auth',
    'password': '$password',
    'port': $port,
    'remoteHome': '$remote_home',
    'pathMappings': $path_mappings
}

with open('$CONFIG_FILE', 'w') as f:
    json.dump(c, f, indent=2)
    f.write('\n')
"

    log "Added target: $name ($user@$host)"
}

cmd_remove() {
    config_exists || die "No config. Run: claude-sync init"
    local name="${1:-}"
    [[ -n "$name" ]] || die "Usage: claude-sync remove <name>"

    python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    c = json.load(f)
if '$name' in c.get('targets', {}):
    del c['targets']['$name']
    with open('$CONFIG_FILE', 'w') as f:
        json.dump(c, f, indent=2)
        f.write('\n')
    print('removed')
else:
    print('not_found')
" | while read -r result; do
        case "$result" in
            removed)    log "Removed target: $name" ;;
            not_found)  err "Target not found: $name" ;;
        esac
    done
}

cmd_list() {
    config_exists || die "No config. Run: claude-sync init"

    echo -e "${BOLD}Claude Sync Targets${NC}"
    echo ""

    local found=false
    while IFS=$'\t' read -r name host user auth; do
        found=true
        local status="${RED}offline${NC}"
        local target_json
        target_json=$(get_target "$name")

        if target_ssh "$target_json" "echo ok" &>/dev/null; then
            status="${GREEN}online${NC}"
        fi

        echo -e "  ${CYAN}${BOLD}$name${NC}  ${user}@${host}  [${status}]  auth:${auth}"
    done < <(get_targets)

    if ! $found; then
        dim "  No targets configured."
        dim "  Add one: claude-sync add <name> --host <ip> --user <user>"
    fi
    echo ""
}

cmd_push() {
    config_exists || die "No config. Run: claude-sync init"
    need rsync

    local target_filter="${1:-}"
    local dry_run=false
    [[ "$target_filter" == "--dry-run" ]] && { dry_run=true; target_filter="${2:-}"; }

    local claude_dir
    claude_dir=$(python3 -c "import json; c=json.load(open('$CONFIG_FILE')); print(c.get('source',{}).get('claudeDir','$HOME/.claude'))")
    local mcp_json
    mcp_json=$(python3 -c "import json; c=json.load(open('$CONFIG_FILE')); print(c.get('source',{}).get('mcpJson','$HOME/.mcp.json'))")

    local sync_items
    sync_items=$(get_sync_items)

    while IFS=$'\t' read -r name host user auth; do
        # Skip if filter specified and doesn't match
        [[ -n "$target_filter" && "$target_filter" != "--dry-run" && "$name" != "$target_filter" ]] && continue

        local target_json
        target_json=$(get_target "$name")

        echo -e "\n${BOLD}${CYAN}── $name ${NC}${DIM}($user@$host)${NC}"

        # Test connectivity
        if ! target_ssh "$target_json" "echo ok" &>/dev/null; then
            err "Cannot connect — skipping"
            continue
        fi

        local remote_home
        remote_home=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('remoteHome', '/home/' + t.get('user','')))")

        # Ensure ~/.claude exists
        target_ssh "$target_json" "mkdir -p $remote_home/.claude" 2>/dev/null

        while IFS= read -r item; do
            if [[ "$item" == ".mcp.json" ]]; then
                # Special case: .mcp.json lives in home, not .claude
                if [[ ! -f "$mcp_json" ]]; then
                    dim "  skip: .mcp.json (not found locally)"
                    continue
                fi
                if $dry_run; then
                    info "would sync: .mcp.json"
                else
                    target_scp "$target_json" "$mcp_json" "$remote_home/.mcp.json"
                    log ".mcp.json"
                fi
            else
                local src="$claude_dir/$item"
                if [[ ! -e "$src" ]]; then
                    dim "  skip: $item (not found locally)"
                    continue
                fi

                if $dry_run; then
                    info "would sync: $item"
                else
                    if [[ -d "$src" ]]; then
                        target_ssh "$target_json" "mkdir -p $remote_home/.claude/$item" 2>/dev/null
                        target_rsync "$target_json" "$src/" "$remote_home/.claude/$item/"
                    else
                        target_scp "$target_json" "$src" "$remote_home/.claude/$item"
                    fi

                    # Fix paths if mappings exist
                    if [[ -f "$src" ]]; then
                        fix_paths_in_file "$name" "$target_json" "$remote_home/.claude/$item"
                    fi

                    log "$item"
                fi
            fi
        done <<< "$sync_items"

    done < <(get_targets)

    echo ""
    log "Sync complete"
}

cmd_pull() {
    die "Pull not implemented yet — claude-sync currently pushes from source to targets"
}

cmd_diff() {
    config_exists || die "No config. Run: claude-sync init"

    local target_name="${1:-}"
    [[ -n "$target_name" ]] || die "Usage: claude-sync diff <target>"

    local target_json
    target_json=$(get_target "$target_name") || die "Target not found: $target_name"

    local remote_home
    remote_home=$(echo "$target_json" | python3 -c "import json,sys; t=json.load(sys.stdin); print(t.get('remoteHome', '/home/' + t.get('user','')))")

    echo -e "${BOLD}Comparing with $target_name${NC}\n"

    local sync_items
    sync_items=$(get_sync_items)

    while IFS= read -r item; do
        local local_path="$HOME/.claude/$item"
        [[ "$item" == ".mcp.json" ]] && local_path="$HOME/.mcp.json"
        local remote_path="$remote_home/.claude/$item"
        [[ "$item" == ".mcp.json" ]] && remote_path="$remote_home/.mcp.json"

        if [[ ! -e "$local_path" ]]; then
            dim "  $item: not found locally"
            continue
        fi

        if [[ -d "$local_path" ]]; then
            local local_count remote_count
            local_count=$(find "$local_path" -type f | wc -l)
            remote_count=$(target_ssh "$target_json" "find $remote_path -type f 2>/dev/null | wc -l" 2>/dev/null || echo "0")

            if [[ "$local_count" == "$remote_count" ]]; then
                log "$item: ${local_count} files (match)"
            else
                warn "$item: local=${local_count} remote=${remote_count}"
            fi
        else
            local local_hash remote_hash
            local_hash=$(md5sum "$local_path" 2>/dev/null | cut -d' ' -f1)
            remote_hash=$(target_ssh "$target_json" "md5sum $remote_path 2>/dev/null | cut -d' ' -f1 || md5 -q $remote_path 2>/dev/null" 2>/dev/null || echo "missing")

            if [[ "$local_hash" == "$remote_hash" ]]; then
                log "$item: in sync"
            else
                warn "$item: differs"
            fi
        fi
    done <<< "$sync_items"
}

cmd_status() {
    config_exists || die "No config. Run: claude-sync init"

    echo -e "${BOLD}Claude Sync Status${NC}"
    echo -e "${DIM}Config: $CONFIG_FILE${NC}\n"

    # Source info
    echo -e "${BOLD}Source (this machine):${NC}"
    echo "  Host: $(hostname)"
    echo "  Claude: $HOME/.claude/"
    echo "  Rules: $(ls "$HOME/.claude/rules/" 2>/dev/null | wc -l) files"
    echo "  Agents: $(ls "$HOME/.claude/agents/" 2>/dev/null | wc -l) files"
    echo "  Skills: $(ls "$HOME/.claude/skills/" 2>/dev/null | wc -l | tr -d ' ') dirs"
    echo "  Hooks: $(ls "$HOME/.claude/hooks/" 2>/dev/null | wc -l) files"
    echo "  MCP: $(test -f "$HOME/.mcp.json" && echo "yes" || echo "no")"
    echo ""

    # Targets
    cmd_list
}

cmd_version() {
    echo "claude-sync v$VERSION"
}

cmd_help() {
    cat << 'EOF'

  claude-sync - Sync Claude Code config across machines

  USAGE
    claude-sync <command> [options]

  COMMANDS
    init                  Create config file
    add <name>            Add a sync target machine
      --host <ip>         SSH host/IP (required)
      --user <user>       SSH username
      --password <pass>   SSH password (or use key auth)
      --port <port>       SSH port (default: 22)
      --home <path>       Remote home dir (auto-detected)
    remove <name>         Remove a sync target
    list                  Show all targets with status
    push [target]         Sync config to targets (or specific target)
      --dry-run           Show what would be synced
    diff <target>         Compare local vs remote config
    status                Show full sync status
    version               Show version
    help                  Show this help

  SYNCED ITEMS (configurable in config.json)
    settings.json         Plugins, hooks, permissions
    rules/                Modular instruction files
    agents/               Custom agent definitions
    skills/               Custom skills
    commands/             Custom slash commands
    hooks/                Hook scripts
    .mcp.json             MCP server configs

  PATH MAPPINGS
    When syncing between Linux and macOS, paths in settings.json
    are automatically rewritten (e.g., /home/user → /Users/user).
    Configured per target in config.json.

  EXAMPLES
    claude-sync init
    claude-sync add macbook --host 192.168.1.50 --user me --password mypass
    claude-sync push
    claude-sync push macbook
    claude-sync diff macbook

EOF
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        init)       cmd_init "$@" ;;
        add)        cmd_add "$@" ;;
        remove|rm)  cmd_remove "$@" ;;
        list|ls)    cmd_list "$@" ;;
        push|sync)  cmd_push "$@" ;;
        pull)       cmd_pull "$@" ;;
        diff)       cmd_diff "$@" ;;
        status)     cmd_status "$@" ;;
        version|-v|--version) cmd_version ;;
        help|-h|--help)       cmd_help ;;
        *)          die "Unknown command: $cmd (try: claude-sync help)" ;;
    esac
}

main "$@"
