#!/usr/bin/env bash
# claude-sync — sync Claude config + projects across machines
#
# Claude config (~/.claude/): Syncthing, bidirectional, automatic.
# Code projects: NAS is canonical. Mac keeps a local copy for fast builds.
#   No SSH. No passwords. Just filesystem mounts.
#
# Usage:
#   claude-sync                  # force Syncthing rescan
#   claude-sync pull-projects    # NAS → local (fast build copy)
#   claude-sync push-projects    # local → NAS (push changes back)
#   claude-sync status           # show sync state
#   claude-sync setup            # first-time setup

set -euo pipefail

CLAUDE_DIR="$HOME/.claude"

# Common rsync excludes (build artifacts, deps — never sync these)
PROJECT_EXCLUDES=(
  --exclude='node_modules/'
  --exclude='target/'
  --exclude='.next/'
  --exclude='build/'
  --exclude='dist/'
  --exclude='.dart_tool/'
  --exclude='.flutter-plugins'
  --exclude='ios/Pods/'
  --exclude='*.o'
  --exclude='*.so'
)

# Detect NAS projects path (works on any machine, LAN or Tailscale)
detect_nas_projects() {
  # Desktop NFS
  [[ -d "/mnt/storage/projects" ]] && echo "/mnt/storage/projects" && return
  # Mac SMB
  [[ -d "/Volumes/projects" ]] && echo "/Volumes/projects" && return
  [[ -d "/Volumes/Media/projects" ]] && echo "/Volumes/Media/projects" && return
  echo ""
}

# Local projects directory (for machines that keep a local copy)
local_projects() {
  echo "$HOME/Documents/projects"
}

# Force Syncthing to rescan ~/.claude/
sync_claude() {
  echo "=== Claude Config ==="
  local api_key
  api_key=$(grep -oP '(?<=<apikey>)[^<]+' "$HOME/.local/state/syncthing/config.xml" 2>/dev/null || \
            grep -oP '(?<=<apikey>)[^<]+' "$HOME/.config/syncthing/config.xml" 2>/dev/null || \
            grep -oP '(?<=<apikey>)[^<]+' "$HOME/Library/Application Support/Syncthing/config.xml" 2>/dev/null || \
            echo "")

  if [[ -n "$api_key" ]]; then
    local folder_id
    folder_id=$(curl -s -H "X-API-Key: $api_key" http://127.0.0.1:8384/rest/config/folders 2>/dev/null | \
      python3 -c "import sys,json; folders=json.load(sys.stdin); print(next((f['id'] for f in folders if '.claude' in f.get('path','')), ''))" 2>/dev/null || echo "")

    if [[ -n "$folder_id" ]]; then
      curl -s -X POST -H "X-API-Key: $api_key" \
        "http://127.0.0.1:8384/rest/db/scan?folder=$folder_id" >/dev/null 2>&1
      echo "Syncthing rescan triggered."
    else
      echo "No .claude folder in Syncthing config."
    fi
  else
    echo "Syncthing not found. Config syncs on next interval."
  fi
}

# NAS → local: get latest before working locally
pull_projects() {
  local nas_projects
  nas_projects=$(detect_nas_projects)
  local local_dir
  local_dir=$(local_projects)

  if [[ -z "$nas_projects" ]]; then
    echo "NAS not mounted."
    echo "  Linux:  mount NFS or check /mnt/storage"
    echo "  Mac:    Finder → Go → Connect to Server → smb://Media/projects"
    return 1
  fi

  # If working directly on NAS (desktop NFS), no copy needed
  if [[ "$PWD" == "$nas_projects"* ]]; then
    echo "You're already working on the NAS. No copy needed."
    return 0
  fi

  echo "=== Pull: NAS → $local_dir ==="
  mkdir -p "$local_dir"
  rsync -av --progress "${PROJECT_EXCLUDES[@]}" \
    "$nas_projects/" "$local_dir/"
  echo "Done. Local copy is up to date."
}

# local → NAS: push changes back after working locally
push_projects() {
  local nas_projects
  nas_projects=$(detect_nas_projects)
  local local_dir
  local_dir=$(local_projects)

  if [[ -z "$nas_projects" ]]; then
    echo "NAS not mounted."
    echo "  Linux:  mount NFS or check /mnt/storage"
    echo "  Mac:    Finder → Go → Connect to Server → smb://Media/projects"
    return 1
  fi

  if [[ ! -d "$local_dir" ]]; then
    echo "No local projects at $local_dir. Nothing to push."
    return 1
  fi

  echo "=== Push: $local_dir → NAS ==="
  rsync -av --progress "${PROJECT_EXCLUDES[@]}" \
    "$local_dir/" "$nas_projects/"
  echo "Done. NAS updated. Other machines see changes immediately."
}

sync_status() {
  echo "=== Claude Config ==="
  if command -v systemctl &>/dev/null; then
    echo "Syncthing:  $(systemctl --user is-active syncthing 2>/dev/null || echo 'not managed by systemd')"
  else
    pgrep -q syncthing && echo "Syncthing:  running" || echo "Syncthing:  not running"
  fi
  echo "Rules:      $(ls "$CLAUDE_DIR/rules/"*.md 2>/dev/null | wc -l) files"
  echo "Skills:     $(ls -d "$CLAUDE_DIR/skills/"*/ 2>/dev/null | wc -l) dirs"
  echo "Hooks:      $(ls "$CLAUDE_DIR/hooks/"*.js 2>/dev/null | wc -l) files"
  echo "Memory:     $(find "$CLAUDE_DIR/projects/" -name "MEMORY.md" 2>/dev/null | wc -l) projects"
  echo ""

  echo "=== Projects ==="
  local nas_projects
  nas_projects=$(detect_nas_projects)
  if [[ -n "$nas_projects" ]]; then
    echo "NAS:        $nas_projects ($(ls "$nas_projects" 2>/dev/null | wc -l) dirs)"
  else
    echo "NAS:        not mounted"
  fi
  local local_dir
  local_dir=$(local_projects)
  if [[ -d "$local_dir" ]]; then
    echo "Local:      $local_dir ($(ls "$local_dir" 2>/dev/null | wc -l) dirs)"
  else
    echo "Local:      none"
  fi
}

setup() {
  echo "Setting up claude-sync..."
  mkdir -p "$CLAUDE_DIR/rules" "$CLAUDE_DIR/skills" "$CLAUDE_DIR/hooks"

  local bin_dir="$HOME/.local/bin"
  mkdir -p "$bin_dir"
  ln -sf "$(realpath "$0")" "$bin_dir/claude-sync"
  echo "Installed: claude-sync → $bin_dir/"

  # Check Syncthing
  if command -v systemctl &>/dev/null; then
    systemctl --user is-active syncthing &>/dev/null && echo "Syncthing: running" || \
      echo "Syncthing: not running — systemctl --user enable --now syncthing"
  else
    pgrep -q syncthing && echo "Syncthing: running" || echo "Syncthing: not running — brew services start syncthing"
  fi

  echo ""
  echo "Done. Commands:"
  echo "  claude-sync               — force Claude config sync"
  echo "  claude-sync pull-projects — NAS → local copy"
  echo "  claude-sync push-projects — local → NAS"
  echo "  claude-sync status        — show everything"
}

case "${1:-}" in
  ""|sync)         sync_claude ;;
  pull-projects)   pull_projects ;;
  push-projects)   push_projects ;;
  status)          sync_status ;;
  setup)           setup ;;
  *)               echo "Usage: claude-sync [pull-projects|push-projects|status|setup]" ;;
esac
